#!/usr/bin/env bash
set -euo pipefail

PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
if [[ -n "${CODEX_TEAM_PLUGIN_VENV:-}" && -x "${CODEX_TEAM_PLUGIN_VENV}/bin/python" ]]; then
  exec "${CODEX_TEAM_PLUGIN_VENV}/bin/python" "$@"
fi
export PYTHONPATH="${PLUGIN_ROOT}/src${PYTHONPATH:+:${PYTHONPATH}}"
exec "${PYTHON:-python3}" "$@"
